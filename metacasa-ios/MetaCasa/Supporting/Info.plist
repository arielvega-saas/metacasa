    <!-- Face ID / Touch ID usage description (requerido por iOS) -->
    <key>NSFaceIDUsageDescription</key>
    <string>Usamos Face ID para proteger tu información financiera. Solo el dueño del dispositivo puede abrir la app.</string>

    <!-- App Transport Security: forzamos HTTPS -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- Privacy - Microphone (para futura voice input) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Opcional: usamos el micrófono para dictar movimientos por voz.</string>

    <!-- Privacy - Speech Recognition (para futura voice input) -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Opcional: reconocemos tu voz para registrar movimientos rápido.</string>

    <!-- Privacy - Photo Library (para adjuntar recibos al asistente) -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Podés enviar fotos de recibos al asistente para que las lea y cargue la transacción automáticamente.</string>

    <!-- Privacy - Camera (para escanear recibos) -->
    <key>NSCameraUsageDescription</key>
    <string>Usamos la cámara para escanear recibos y convertirlos en transacciones.</string>

    <!-- Live Activities support (Lock Screen + Dynamic Island).
         Habilita ActivityKit para mostrar el próximo vencimiento. -->
    <key>NSSupportsLiveActivities</key>
    <true/>
</dict>
</plist>
