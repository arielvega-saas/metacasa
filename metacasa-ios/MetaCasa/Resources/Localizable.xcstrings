    "assistant.subtitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "On-device · Private" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "On-device · Privado" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "No dispositivo · Privado" } } } },
    "assistant.welcome" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hi 👋 I'm your MetaHome assistant. I can:\n\n• Analyze your spending and projections\n• Read photos of receipts (tap 📎)\n• Import transactions from CSV\n• Voice dictation (tap 🎙️)\n\nEverything runs on-device. Your data doesn't leave your iPhone." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Hola 👋 Soy tu asistente de MetaCasa. Puedo:\n\n• Analizar tus gastos y proyecciones\n• Leer fotos de recibos (tap en 📎)\n• Cargar transacciones desde CSV\n• Dictado de voz (tap en 🎙️)\n\nTodo corre on-device. Tus datos no salen del iPhone." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Olá 👋 Sou seu assistente do MetaCasa. Posso:\n\n• Analisar gastos e projeções\n• Ler fotos de recibos (toque em 📎)\n• Importar transações de CSV\n• Ditado de voz (toque em 🎙️)\n\nTudo roda no dispositivo. Seus dados não saem do iPhone." } } } },
    "assistant.input.placeholder" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ask me or dictate…" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Preguntame o dictá…" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Pergunte ou dite…" } } } },
    "assistant.input.listening" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Listening…" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Escuchando…" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Ouvindo…" } } } },
    "assistant.thinking" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Analyzing your data…" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Analizando tus datos…" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Analisando seus dados…" } } } },
    "assistant.recording" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recording… speak now" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Grabando… hablá ahora" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Gravando… fale agora" } } } },
