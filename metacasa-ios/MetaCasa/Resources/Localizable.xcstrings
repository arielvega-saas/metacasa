    "compound.disclaimer" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Projection uses fixed rate and monthly compounding. Real returns depend on inflation, taxes, fees, and market volatility. Not financial advice." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "La proyección asume tasa fija y capitalización mensual. Los retornos reales dependen de inflación, impuestos, comisiones y volatilidad del mercado. No es asesoramiento financiero." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "A projeção assume taxa fixa e capitalização mensal. Retornos reais dependem de inflação, impostos, taxas e volatilidade. Não é aconselhamento financeiro." } } } },
