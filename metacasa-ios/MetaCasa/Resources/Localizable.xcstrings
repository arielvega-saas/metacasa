    "Asistente IA" : { "comment" : "AssistantConsentSheet header title", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "AI Assistant" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Assistente IA" } } } },
    "Antes de empezar, tu consentimiento" : { "comment" : "Consent sheet subtitle", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Before we start, your consent" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Antes de começar, seu consentimento" } } } },
    "En tu iPhone (siempre)" : { "comment" : "Consent — on-device bullet title", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "On your iPhone (always)" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "No seu iPhone (sempre)" } } } },
    "Reconocimiento de voz, OCR de recibos y análisis básico corren on-device con Apple Speech y Vision. No salen del dispositivo." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Speech recognition, receipt OCR and basic analysis run on-device with Apple Speech and Vision. They never leave your iPhone." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Reconhecimento de voz, OCR de recibos e análise básica rodam no dispositivo com Apple Speech e Vision. Não saem do iPhone." } } } },
    "En la nube (solo cuando hace falta)" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "In the cloud (only when needed)" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Na nuvem (apenas quando necessário)" } } } },
    "Las preguntas complejas se procesan con Claude (Anthropic). Enviamos tu pregunta + un resumen de tus datos (montos, categorías, fechas). Nunca emails, ni tarjetas, ni contraseñas." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Complex questions are processed with Claude (Anthropic). We send your question + a summary of your data (amounts, categories, dates). Never emails, cards, or passwords." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Perguntas complexas são processadas com Claude (Anthropic). Enviamos sua pergunta + um resumo dos seus dados (valores, categorias, datas). Nunca emails, cartões ou senhas." } } } },
    "Tu data no se usa para entrenar" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your data isn't used for training" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Seus dados não são usados para treinar" } } } },
    "Anthropic NO entrena modelos con consultas de su API. Las conversaciones no se guardan en servidores nuestros más allá de tu propia sesión." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Anthropic does NOT train models with API queries. Conversations are not retained on our servers beyond your own session." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Anthropic NÃO treina modelos com consultas da API. As conversas não são guardadas em nossos servidores além da sua sessão." } } } },
    "Tus derechos" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your rights" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Seus direitos" } } } },
    "Podés revocar el consentimiento o activar el modo solo on-device en cualquier momento desde Ajustes → Privacidad. Detalles en nuestra Política de Privacidad." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You can revoke consent or enable on-device-only mode anytime from Settings → Privacy. Details in our Privacy Policy." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Você pode revogar o consentimento ou ativar o modo somente no dispositivo a qualquer momento em Ajustes → Privacidade. Detalhes na nossa Política de Privacidade." } } } },
    "Aceptar y continuar" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Accept and continue" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Aceitar e continuar" } } } },
    "Usar solo on-device (más lento)" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Use only on-device (slower)" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Usar somente no dispositivo (mais lento)" } } } },

    "Privacidad del Asistente" : { "comment" : "AssistantPrivacyView title", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Assistant Privacy" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Privacidade do Assistente" } } } },
    "Privacidad del Asistente IA" : { "comment" : "Settings nav row label", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "AI Assistant Privacy" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Privacidade do Assistente IA" } } } },
    "Vos decidís qué pasa con tu data" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You decide what happens with your data" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Você decide o que acontece com seus dados" } } } },
    "Estos controles son inmediatos y persistentes — los respetamos en todos los modos (chat, voz, vision)." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "These controls are immediate and persistent — we honor them in every mode (chat, voice, vision)." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Estes controles são imediatos e persistentes — respeitamos em todos os modos (chat, voz, visão)." } } } },
    "Procesamiento en la nube" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cloud processing" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Processamento na nuvem" } } } },
    "Permite usar Claude (Anthropic) para consultas complejas." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Allow Claude (Anthropic) for complex queries." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Permite usar Claude (Anthropic) para consultas complexas." } } } },
    "Forzar solo on-device" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Force on-device only" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Forçar somente no dispositivo" } } } },
    "El asistente usa solo Apple Intelligence on-device. Más lento, pero ningún dato sale del iPhone." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The assistant uses only on-device Apple Intelligence. Slower, but no data leaves your iPhone." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O assistente usa apenas Apple Intelligence no dispositivo. Mais lento, mas nenhum dado sai do iPhone." } } } },
    "Qué procesamos" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "What we process" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O que processamos" } } } },
    "Reconocimiento de voz y OCR de recibos siempre on-device (Apple Speech + Vision)." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Speech recognition and receipt OCR are always on-device (Apple Speech + Vision)." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Reconhecimento de voz e OCR de recibos sempre no dispositivo (Apple Speech + Vision)." } } } },
    "Si activás cloud: tu pregunta + un resumen de tus datos (montos, categorías) van a Claude. Nunca emails, ni tarjetas, ni contraseñas." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "If cloud is on: your question + a summary of your data (amounts, categories) go to Claude. Never emails, cards, or passwords." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Se a nuvem está ativa: sua pergunta + um resumo dos seus dados (valores, categorias) vão para o Claude. Nunca emails, cartões ou senhas." } } } },
    "Anthropic NO entrena modelos con consultas de su API." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Anthropic does NOT train models with API queries." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Anthropic NÃO treina modelos com consultas da API." } } } },
    "Tus conversaciones se guardan localmente en tu iPhone (encriptado). Podés borrarlas desde acá." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your conversations are stored locally on your iPhone (encrypted). You can delete them from here." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Suas conversas ficam salvas localmente no iPhone (criptografadas). Você pode apagar daqui." } } } },
    "Revocar consentimiento y borrar historial" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Revoke consent and delete history" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Revogar consentimento e apagar histórico" } } } },
    "¿Revocar consentimiento y borrar historial del Asistente?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Revoke consent and delete Assistant history?" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Revogar consentimento e apagar histórico do Assistente?" } } } },
    "Revocar y borrar" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Revoke and delete" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Revogar e apagar" } } } },
    "Cancelar" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cancel" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Cancelar" } } } },
    "Vas a borrar el historial guardado del Asistente IA en este hogar. La próxima vez que abras el chat, te pedimos consentimiento de nuevo." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You're about to delete the AI Assistant history stored for this household. Next time you open the chat, we'll ask for consent again." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Você vai apagar o histórico salvo do Assistente IA neste lar. Da próxima vez que abrir o chat, pediremos consentimento novamente." } } } },

    "Cómo procesamos tu data en el Asistente IA" : { "comment" : "Settings footer link to assistant-ai disclosure", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "How we process your data in the AI Assistant" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Como processamos seus dados no Assistente IA" } } } },

    "Escanear recibo" : { "comment" : "Attachments menu — scan receipt option", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Scan receipt" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Digitalizar recibo" } } } }
  }
