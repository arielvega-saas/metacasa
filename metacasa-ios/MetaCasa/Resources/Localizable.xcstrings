    "onboarding.subtitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Complete these steps to get the most out of the app." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Completá estos pasos para aprovechar la app al máximo." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Complete estes passos para aproveitar a app ao máximo." } } } },
