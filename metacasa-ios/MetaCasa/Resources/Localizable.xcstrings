    "onboarding.step.account.desc" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checking, savings, cash, credit card… so you can track where your money lives." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Corriente, ahorro, efectivo, tarjeta… así seguís dónde está tu plata." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Corrente, poupança, dinheiro, cartão… para saber onde está seu dinheiro." } } } },
