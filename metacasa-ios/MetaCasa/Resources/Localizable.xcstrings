    "tour.page1.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your household finances, in calm" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Las finanzas de tu hogar, en calma" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "As finanças da sua casa, com calma" } } } },
    "tour.page1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Log expenses, track budgets, reach goals — alone or with your family in the same household." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Cargá gastos, seguí presupuestos, alcanzá metas — solo/a o compartiendo el hogar con tu pareja o familia." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Registre gastos, acompanhe orçamentos, alcance metas — sozinho ou com a família na mesma casa." } } } },

    "tour.page2.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Envelope budget, done right" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Presupuesto envelope, bien hecho" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Orçamento envelope, feito certo" } } } },
    "tour.page2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Allocate each peso before spending. Every category is an envelope that depletes as you log transactions." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Asigná cada peso antes de gastarlo. Cada categoría es un sobre que se va vaciando con tus movimientos." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Aloque cada real antes de gastar. Cada categoria é um envelope que se esvazia com seus movimentos." } } } },
    "tour.page2.b1" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Color-coded traffic light per category" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Semáforo visual por categoría" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Semáforo visual por categoria" } } } },
    "tour.page2.b2" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Visual cascade (Sankey) for savings and investments" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Cascada visual (Sankey) de ahorro e inversión" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Cascata visual (Sankey) de poupança e investimento" } } } },
    "tour.page2.b3" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "See what's left \"to assign\" in real time" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Ves lo que queda \"por asignar\" en vivo" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Veja quanto falta \"para alocar\" em tempo real" } } } },

    "tour.page3.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Goals with ETA" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Metas con ETA" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Metas com previsão" } } } },
    "tour.page3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Set amount, optional target date, and contribute little by little. The app computes if you're on track." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Ponés monto, fecha opcional y contribuís de a poco. La app calcula si vas en camino a llegar." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Defina valor, data opcional e contribua aos poucos. A app calcula se está no caminho certo." } } } },
    "tour.page3.b1" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Confetti animation when you hit 100%" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Confetti cuando llegás al 100%" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Confetti quando chega a 100%" } } } },
    "tour.page3.b2" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Monthly reminders at day 1 at 10am (configurable)" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Recordatorio mensual día 1 a las 10am (configurable)" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Lembrete mensal dia 1 às 10h (configurável)" } } } },

    "tour.page4.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your financial assistant" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Tu asistente financiero" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Seu assistente financeiro" } } } },
    "tour.page4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ask anything about your money or the app. It knows your data AND how the app works." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Preguntale cualquier cosa de tu plata o de la app. Conoce tus datos Y cómo funciona cada feature." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Pergunte qualquer coisa sobre seu dinheiro ou a app. Conhece seus dados E como funcionam os recursos." } } } },
    "tour.page4.b1" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "\"How am I doing this month?\" → live analysis" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "«¿Cómo voy este mes?» → análisis en vivo" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "\"Como estou este mês?\" → análise ao vivo" } } } },
    "tour.page4.b2" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "\"How do I add a recurring bill?\" → step-by-step guide" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "«¿Cómo agrego un vencimiento?» → pasos concretos" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "\"Como adiciono uma conta?\" → passo a passo" } } } },
    "tour.page4.b3" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Actionable advice with real numbers" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Consejos accionables con números concretos" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Conselhos acionáveis com números reais" } } } },

    "tour.page5.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Private by design" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Privacidad por diseño" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Privacidade por design" } } } },
    "tour.page5.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your money data stays on your iPhone. No tracking, no ads, no selling data." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Tus datos financieros se quedan en tu iPhone. Sin tracking, sin ads, sin venta de data." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Seus dados ficam no seu iPhone. Sem tracking, sem anúncios, sem venda de dados." } } } },
    "tour.page5.b1" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "AI runs on-device (Apple Intelligence, iOS 26+)" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "IA corre on-device (Apple Intelligence, iOS 26+)" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "IA roda no dispositivo (Apple Intelligence, iOS 26+)" } } } },
    "tour.page5.b2" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Face ID / Touch ID to unlock the app" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Face ID / Touch ID para desbloquear la app" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Face ID / Touch ID para desbloquear a app" } } } },
    "tour.page5.b3" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Supabase-encrypted backup, full JSON export" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Backup JSON full cifrado en Supabase" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Backup JSON cifrado no Supabase" } } } },

