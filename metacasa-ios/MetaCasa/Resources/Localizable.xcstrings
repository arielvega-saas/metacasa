    "import.duplicates.section" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Duplicates detected" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Duplicados detectados" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Duplicados detectados" } } } },
    "import.duplicates.hint" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "By default duplicates are skipped. Toggle any you want to import anyway." } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Por defecto los duplicados se saltean. Activá los que quieras importar igual." } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Por padrão duplicados são pulados. Ative os que quer importar mesmo assim." } } } },
    "import.duplicates.importAll" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Import all" } }, "es" : { "stringUnit" : { "state" : "translated", "value" : "Importar todos" } }, "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Importar todos" } } } },
